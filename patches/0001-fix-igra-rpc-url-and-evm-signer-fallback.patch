--- a/crates/common/src/provider/mod.rs
+++ b/crates/common/src/provider/mod.rs
@@ -176,7 +176,20 @@ pub fn new(url_str: &str) -> Self {
     pub fn from_config(config: &Config) -> Result<Self> {
         config.igra.validate().wrap_err("invalid IGRA configuration")?;
 
-        let url = config.get_rpc_url_or_localhost_http()?;
+        // When IGRA is enabled and no explicit --rpc-url / ETH_RPC_URL was provided,
+        // fall back to el_rpc_url from the IGRA config section before defaulting to
+        // localhost:8545.
+        let url = if let Some(url) = config.get_rpc_url() {
+            url?
+        } else if config.igra.enabled {
+            if let Some(ref el_url) = config.igra.el_rpc_url {
+                std::borrow::Cow::Owned(el_url.clone())
+            } else {
+                std::borrow::Cow::Borrowed("http://localhost:8545")
+            }
+        } else {
+            std::borrow::Cow::Borrowed("http://localhost:8545")
+        };
         let mut builder = Self::new(url.as_ref());
 
         builder = builder.accept_invalid_certs(config.eth_rpc_accept_invalid_certs);
