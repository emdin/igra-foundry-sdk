+    /// Returns the EVM signer, falling back to the IGRA kaspa_wallet private key
+    /// when IGRA is enabled and no explicit EVM key source was provided.
+    ///
+    /// In IGRA mode, both the EVM L2 address and the Kaspa L1 address are derived
+    /// from the same private key, so reusing `kaspa_wallet.private_key` as the EVM
+    /// signer is expected behaviour when no separate EVM key is given.
+    pub async fn signer_with_igra_fallback(&self, config: &Config) -> Result<WalletSigner> {
+        match self.signer().await {
+            Ok(signer) => Ok(signer),
+            Err(_) if config.igra.enabled => {
+                if let Some(ref pk) = config.igra.kaspa_wallet.private_key {
+                    utils::create_private_key_signer(pk)
+                        .map_err(|e| eyre::eyre!("IGRA EVM signer fallback failed: {e}"))
+                } else if let Some(ref mnemonic) = config.igra.kaspa_wallet.mnemonic {
+                    utils::create_mnemonic_signer(
+                        mnemonic,
+                        config.igra.kaspa_wallet.mnemonic_passphrase.as_deref(),
+                        config.igra.kaspa_wallet.mnemonic_derivation_path.as_deref(),
+                        config.igra.kaspa_wallet.mnemonic_index.unwrap_or(0),
+                    )
+                    .map_err(|e| eyre::eyre!("IGRA EVM signer fallback from mnemonic failed: {e}"))
+                } else {
+                    eyre::bail!(
+                        "IGRA mode is enabled but no wallet key was found. \
+                         Provide --private-key, --private-key-kaspa, or set \
+                         kaspa_wallet.private_key in foundry.toml"
+                    )
+                }
+            }
+            Err(e) => Err(e),
+        }
+    }
